# =============================================================================
# FortiMonitor MCP Server - Environment Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env: cp .env.example .env
#   2. Replace 'your_api_key_here' with your actual FortiMonitor API key
#   3. Adjust other settings as needed
#
# DOCKER USAGE:
#   - docker-compose up -d
#   OR
#   - docker run -e FORTIMONITOR_API_KEY=your-key unofficial-fortimonitor-mcp
#
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: FortiMonitor API Configuration
# -----------------------------------------------------------------------------

# Your FortiMonitor/Panopta API key (REQUIRED)
# Get this from your FortiMonitor account settings
FORTIMONITOR_API_KEY=your_api_key_here

# FortiMonitor API base URL (usually no need to change)
FORTIMONITOR_BASE_URL=https://api2.panopta.com/v2

# -----------------------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------------------

# Server identification (shown in Claude Desktop)
MCP_SERVER_NAME=unofficial-fortimonitor-mcp
MCP_SERVER_VERSION=1.0.0

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Caching Configuration
# -----------------------------------------------------------------------------

# Enable schema caching for better performance
ENABLE_SCHEMA_CACHE=true

# Cache directory (auto-created if doesn't exist)
# For Docker: /app/cache/schemas (default)
# For local dev: cache/schemas
SCHEMA_CACHE_DIR=cache/schemas

# Cache TTL in seconds (default: 24 hours)
SCHEMA_CACHE_TTL=86400

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------

# Maximum API requests per period
RATE_LIMIT_REQUESTS=100

# Rate limit period in seconds
RATE_LIMIT_PERIOD=60

# -----------------------------------------------------------------------------
# Knowledge Layer Configuration (v2.0)
# -----------------------------------------------------------------------------

# Path to the LanceDB vector store
# For Docker: /app/data/vectordb (default)
# For local dev: data/vectordb
KNOWLEDGE_BASE_PATH=data/vectordb

# Sentence-transformers embedding model
KNOWLEDGE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunk size in tokens for document splitting
KNOWLEDGE_CHUNK_SIZE=800

# Overlap between chunks in tokens
KNOWLEDGE_CHUNK_OVERLAP=100

# Auto-ingest documentation on first launch if store is empty
KNOWLEDGE_AUTO_INGEST=true

# Path to documentation sources config
KNOWLEDGE_SOURCES_FILE=data/sources.yaml
